# ============================================
# MASTER .gitignore for FYP Project
# ============================================

#  1. ENVIRONMENT VARIABLES (Sabse Important - Kabhi commit na karein!)
.env
.env.local
.env.development
.env.development.local
.env.test.local
.env.production
.env.production.local
.env.test
*.env.*

# 🔑 2. SECRETS & KEYS
secrets.json
credentials.json
*.pem
*.key
*.crt

#  3. DEPENDENCIES (Bahut bade folders hote hain)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# Python/Django Virtual Environments
venv/
env/
ENV/
env.bak/
venv.bak/
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# 🗄️ 4. DATABASE & MEDIA (User uploaded files & local DB)
*.db
*.sqlite
*.sqlite3
*.sqlite3-journal
db.sqlite3
db.sqlite3-journal
media/
staticfiles/
collected_static/
static_root/

# ⚛️ 5. BUILD OUTPUTS (React/Vite build folders)
dist/
dist-ssr/
build/
.next/
out/
.vite/
.turbo/
.vercel/

# 💻 6. IDE & EDITOR FILES
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-workspace
*.sublime-project
*.code-workspace
project.iml

# 🖥️ 7. OS & SYSTEM FILES
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
~$*
*.lnk

# 📝 8. LOGS & TEMPORARY FILES
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.tmp
*.temp
*.bak
*.old
*.orig
celerybeat-schedule
celerybeat.pid

# 🧪 9. TESTING & COVERAGE
coverage/
.nyc_output/
.pytest_cache/
.tox/
.nox/
htmlcov/
.coverage
*.cover

# 🐍 10. DJANGO SPECIFIC
config/settings_local.py
config/settings_dev.py
*.mo
*.pot

# ⚛️ 11. REACT/VITE SPECIFIC
.eslintcache
.stylelintcache
.cache
.pnp
.pnp.js
*.tsbuildinfo